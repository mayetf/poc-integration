# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ─── SurveySparrow ────────────────────────────────────────────────────────────
# Found in: Settings > Developer > API Tokens
SURVEYSPARROW_ACCESS_TOKEN=your_access_token_here

# Your SurveySparrow account subdomain (e.g. "mycompany" → mycompany.surveysparrow.com)
SURVEYSPARROW_DOMAIN=your_domain

# The survey token used in embed codes (found in Share > Embed)
SURVEYSPARROW_TOKEN_POC1A=tt-xxxxxxxxxxxxxxxx
SURVEYSPARROW_TOKEN_POC1B=tt-xxxxxxxxxxxxxxxx
SURVEYSPARROW_TOKEN_POC1C=tt-xxxxxxxxxxxxxxxx

# Secret to validate incoming webhook signatures from SurveySparrow
# Set in: Settings > Webhooks > Secret
SURVEYSPARROW_WEBHOOK_SECRET=your_webhook_secret

# ─── Onomi / SpotMe ───────────────────────────────────────────────────────────
# API base URL — confirm with your Onomi account manager
# Example: https://api.onomi.io/v1  or  https://app.spotme.com/api/v1
ONOMI_API_BASE_URL=https://api.onomi.io/v1

# API key provided by Onomi/SpotMe
ONOMI_API_KEY=your_onomi_api_key_here

# Onomi event namespace / organisation slug (if required by your plan)
ONOMI_ORG_ID=your_org_id
